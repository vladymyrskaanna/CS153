# AI Intelligence — backend configuration. Copy to `.env` and fill in.

# Postgres connection. Expects the `ai_intelligence` database loaded from
# backend/sql/sample-data.sql (see README).
DATABASE_URL="postgresql://<user>@localhost:5432/ai_intelligence"

# Any non-empty string — signs the session cookie. Server won't start without it.
SESSION_SECRET="change-me-to-a-long-random-string"

# API port (default 4041). The Vite dev server proxies /api here.
API_PORT=4041
